{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --workspace=packages/backend && npm run build --workspace=packages/backend"
  },
  "deploy": {
    "startCommand": "cd packages/backend && DATABASE_URL=$DATABASE_URL_MIGRATE npx prisma migrate deploy && node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
