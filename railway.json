{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --workspace=packages/backend && npm run build --workspace=packages/backend"
  },
  "deploy": {
    "startCommand": "npm run db:migrate:deploy --workspace=packages/backend && npm run start --workspace=packages/backend",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
