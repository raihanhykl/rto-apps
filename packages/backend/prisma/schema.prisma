generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum MotorModel {
  ATHENA
  VICTORY
  EDPOWER
}

enum BatteryType {
  REGULAR
  EXTENDED
}

enum ContractStatus {
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
  REPOSSESSED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  VOID
}

enum InvoiceType {
  DP
  DP_INSTALLMENT
  DAILY_BILLING
  MANUAL_PAYMENT
}

enum DPScheme {
  FULL
  INSTALLMENT
}

enum Gender {
  MALE
  FEMALE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  EXPORT
}

enum HolidayScheme {
  OLD_CONTRACT
  NEW_CONTRACT
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum PaymentDayStatus {
  UNPAID
  PENDING
  PAID
  HOLIDAY
  VOIDED
  COMPENSATED
}

enum SavingTransactionType {
  CREDIT
  DEBIT_SERVICE
  DEBIT_TRANSFER
  DEBIT_CLAIM
  REVERSAL
}

enum ServiceType {
  MINOR
  MAJOR
}

enum ServiceRecordStatus {
  ACTIVE
  REVOKED
}

// ============ MODELS ============

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  fullName  String   @map("full_name")
  role      UserRole @default(ADMIN)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Customer {
  id                String    @id @default(uuid())
  fullName          String    @map("full_name")
  phone             String
  email             String
  address           String
  birthDate         String?   @map("birth_date")
  gender            Gender?
  rideHailingApps   String[]  @map("ride_hailing_apps")
  ktpNumber         String    @unique @map("ktp_number")
  ktpPhoto          String?   @map("ktp_photo")
  simPhoto          String?   @map("sim_photo")
  kkPhoto           String?   @map("kk_photo")
  guarantorName     String    @default("") @map("guarantor_name")
  guarantorPhone    String    @default("") @map("guarantor_phone")
  guarantorKtpPhoto String?   @map("guarantor_ktp_photo")
  spouseName        String    @default("") @map("spouse_name")
  spouseKtpPhoto    String?   @map("spouse_ktp_photo")
  notes             String    @default("")
  isDeleted         Boolean   @default(false) @map("is_deleted")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  contracts Contract[]
  invoices  Invoice[]

  @@index([isDeleted])
  @@map("customers")
}

model Contract {
  id              String         @id @default(uuid())
  contractNumber  String         @unique @map("contract_number")
  customerId      String         @map("customer_id")
  motorModel      MotorModel     @map("motor_model")
  batteryType     BatteryType    @map("battery_type")
  dailyRate       Float          @map("daily_rate")
  durationDays    Int            @map("duration_days")
  totalAmount     Float          @map("total_amount")
  startDate       DateTime       @map("start_date")
  endDate         DateTime       @map("end_date")
  status          ContractStatus @default(ACTIVE)
  notes           String         @default("")
  createdBy       String         @map("created_by")

  // Unit details
  color        String @default("")
  year         Int?
  vinNumber    String @default("") @map("vin_number")
  engineNumber String @default("") @map("engine_number")

  // DP fields
  dpAmount     Float    @map("dp_amount")
  dpScheme     DPScheme @map("dp_scheme")
  dpPaidAmount Float    @default(0) @map("dp_paid_amount")
  dpFullyPaid  Boolean  @default(false) @map("dp_fully_paid")

  // Unit delivery & billing
  unitReceivedDate    DateTime? @map("unit_received_date")
  billingStartDate    DateTime? @map("billing_start_date")
  bastPhoto           String?   @map("bast_photo")
  bastNotes           String    @default("") @map("bast_notes")
  holidayScheme       HolidayScheme @default(NEW_CONTRACT) @map("holiday_scheme")

  // RTO fields
  ownershipTargetDays Int       @default(1278) @map("ownership_target_days")
  totalDaysPaid       Int       @default(0) @map("total_days_paid")
  workingDaysPaid     Int       @default(0) @map("working_days_paid")
  holidayDaysPaid     Int       @default(0) @map("holiday_days_paid")
  compensatedDaysPaid Int       @default(0) @map("compensated_days_paid")
  ownershipProgress   Float     @default(0) @map("ownership_progress")
  gracePeriodDays     Int       @default(7) @map("grace_period_days")
  savingBalance       Int       @default(0) @map("saving_balance")
  repossessedAt       DateTime? @map("repossessed_at")
  completedAt         DateTime? @map("completed_at")
  isDeleted           Boolean   @default(false) @map("is_deleted")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  customer           Customer             @relation(fields: [customerId], references: [id])
  invoices           Invoice[]
  paymentDays        PaymentDay[]
  savingTransactions SavingTransaction[]
  serviceRecords     ServiceRecord[]

  @@index([customerId])
  @@index([status])
  @@index([isDeleted])
  @@index([status, isDeleted])
  @@index([createdAt])
  @@map("contracts")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique @map("invoice_number")
  contractId    String        @map("contract_id")
  customerId    String        @map("customer_id")
  amount        Float
  lateFee       Float         @default(0) @map("late_fee")
  type          InvoiceType
  status        PaymentStatus @default(PENDING)
  qrCodeData    String        @default("") @map("qr_code_data")
  dueDate       DateTime      @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  extensionDays Int?          @map("extension_days")

  // DOKU
  dokuPaymentUrl  String? @map("doku_payment_url")
  dokuReferenceId String? @map("doku_reference_id")

  // Payment period (for daily billing and manual payments)
  dailyRate         Float?    @map("daily_rate")
  daysCount         Int?      @map("days_count")
  periodStart       DateTime? @map("period_start")
  periodEnd         DateTime? @map("period_end")
  expiredAt         DateTime? @map("expired_at")
  previousPaymentId String?   @map("previous_payment_id")
  isHoliday         Boolean   @default(false) @map("is_holiday")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract           Contract             @relation(fields: [contractId], references: [id])
  customer           Customer             @relation(fields: [customerId], references: [id])
  previousPayment    Invoice?             @relation("PaymentChain", fields: [previousPaymentId], references: [id])
  nextPayments       Invoice[]            @relation("PaymentChain")
  paymentDays        PaymentDay[]
  savingTransactions SavingTransaction[]

  @@index([contractId])
  @@index([customerId])
  @@index([status])
  @@index([previousPaymentId])
  @@index([contractId, status, type])
  @@index([createdAt])
  @@index([dueDate])
  @@map("invoices")
}

model AuditLog {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  action      AuditAction
  module      String
  entityId    String      @map("entity_id")
  description String
  metadata    Json        @default("{}")
  ipAddress   String      @default("") @map("ip_address")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@map("audit_logs")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String   @default("")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model PaymentDay {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  date       DateTime
  status     PaymentDayStatus @default(UNPAID)
  paymentId  String?          @map("payment_id")
  dailyRate  Float            @map("daily_rate")
  amount     Float            @default(0)
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id])
  payment  Invoice? @relation(fields: [paymentId], references: [id])

  @@unique([contractId, date])
  @@index([contractId, status])
  @@index([paymentId])
  @@map("payment_days")
}

model SavingTransaction {
  id            String                 @id @default(uuid())
  contractId    String                 @map("contract_id")
  type          SavingTransactionType
  amount        Int                    // Selalu positif. Arah ditentukan oleh type (CREDIT=masuk, DEBIT_*=keluar, REVERSAL=keluar)
  balanceBefore Int                    @map("balance_before")
  balanceAfter  Int                    @map("balance_after")

  // Referensi sumber transaksi
  paymentId     String?                @map("payment_id")     // FK ke Invoice (untuk CREDIT / REVERSAL)
  daysCount     Int?                   @map("days_count")     // Jumlah hari yang menghasilkan saving (untuk CREDIT)

  // Detail transaksi (untuk DEBIT)
  description   String?                // "Service rem + ganti kampas", "Biaya balik nama STNK", dll.
  photo         String?                // URL foto bukti (nota servis, kwitansi, dll.)

  // Admin & audit
  createdBy     String                 @map("created_by")     // Admin user ID yang melakukan transaksi
  notes         String?                // Catatan tambahan admin

  createdAt     DateTime               @default(now()) @map("created_at")

  // Relations
  contract      Contract               @relation(fields: [contractId], references: [id])
  payment       Invoice?               @relation(fields: [paymentId], references: [id])

  @@index([contractId])
  @@index([paymentId])
  @@index([type])
  @@map("saving_transactions")
}

model ServiceRecord {
  id                  String              @id @default(uuid())
  contractId          String              @map("contract_id")
  serviceType         ServiceType         @map("service_type")
  replacementProvided Boolean             @default(false) @map("replacement_provided")
  startDate           DateTime            @map("start_date")
  endDate             DateTime            @map("end_date")
  compensationDays    Int                 @default(0) @map("compensation_days")
  notes               String              @default("")
  attachment          String?

  daySnapshots        Json?               @map("day_snapshots")

  status              ServiceRecordStatus @default(ACTIVE)
  revokedAt           DateTime?           @map("revoked_at")
  revokedBy           String?             @map("revoked_by")
  revokeReason        String?             @map("revoke_reason")

  createdBy           String              @map("created_by")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([status])
  @@map("service_records")
}
