# Server
PORT=3001
NODE_ENV=development

# CORS - Frontend URL
CORS_ORIGIN=http://localhost:3000

# Database - Kosongkan/hapus untuk pakai In-Memory (local dev tanpa DB)
DATABASE_URL=postgresql://postgres:password@localhost:5432/wedison_rto

# JWT Authentication
# JWT_SECRET WAJIB di-set di production (server crash jika masih default)
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed — Password untuk user seed (WAJIB diisi sebelum menjalankan seed)
SEED_DEFAULT_PASSWORD=
# Opsional: override password per user (fallback ke SEED_DEFAULT_PASSWORD jika kosong)
# SEED_SUPERADMIN_PASSWORD=
# SEED_ADMIN_PASSWORD=
# SEED_VIEWER_PASSWORD=

# Future: DOKU Payment Gateway
# DOKU_CLIENT_ID=
# DOKU_SECRET_KEY=
# DOKU_BASE_URL=

# Future: WhatsApp API
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=